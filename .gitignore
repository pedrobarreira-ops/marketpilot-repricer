.env
.env.local
.env.production
.env.*.local
node_modules/
__pycache__/
*.pyc
.DS_Store
.mcp.json
*.db
*.db-shm
*.db-wal

# Local dev state — not shared across machines
.worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/bad-statusline.sh
skills-lock.json

# (Removed 2026-05-03) `.claude/skills/bad/` was previously gitignored as a
# "runtime copy" of an `.agents/skills/bad/` canonical source. That canonical
# location does not exist in this repo. The `.claude/skills/bad/` directory
# IS the source — and it's been customized for marketpilot-repricer (paths,
# Worker-Path Opus Gate, mcp-forbidden-patterns, etc. — see
# `_bmad-output/implementation-artifacts/bad-customization-notes.md`). The
# customizations are intentional and durable; track them. If you ever want
# to update from upstream BAD, do a manual three-way merge with the
# customization notes as the changelist.

# BMAD per-user config — canonical module files stay in _bmad/
_bmad/config.user.yaml
_bmad/module-help.csv

# Playwright E2E artifacts — regenerated on each run
playwright-report/
test-results/
playwright/.cache/

# Local preview/export artifacts — not served by the app
_artifacts/
public/*-standalone.html

# Mirakl verification artifacts — contain Gabriel's shop data; redacted
# summaries are referenced inline in architecture.md. Raw JSON stays local.
verification-results.json
verification-stderr.log

# Build + test output
dist/
coverage/
.env.test
tmp/

# Transient diagnostic / debug output (e.g. supabase CLI --debug captures)
supabase-debug*.log
supabase-*-attempt.log

# Review-process scratch artifacts (e.g. .review-N.M/ diff bundles)
_bmad-output/implementation-artifacts/.review-*/
