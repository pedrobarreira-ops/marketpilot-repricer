# Force LF for all shell scripts and git hooks — Coolify runs them in Linux
# containers, which choke on CRLF shebangs. Pedro's Windows clone keeps LF
# in working tree thanks to this rule, no autocrlf surprise.
*.sh text eol=lf
.githooks/* text eol=lf

# Force LF for CSV test fixtures — byte-exact golden-file tests require LF
# endings; autocrlf=true on Windows would corrupt the comparison otherwise.
tests/fixtures/**/*.csv text eol=lf
