# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE_DATABASE_URL=

# Encryption
# 32-byte master key, base64-encoded. Generate with: openssl rand -base64 32
MASTER_KEY_BASE64=

# App
PORT=3000

# Stripe (needed at import time by stripe SDK — set to sk_test_ for local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=

# Logging
# pino log level: trace|debug|info|warn|error|fatal. Default 'info' if unset.
# LOG_LEVEL=info
