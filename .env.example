# Supabase
SUPABASE_URL=
# Supabase project anon API key (JWT-style, starts with eyJ...). Used by
# the public-flow auth client for signUp / signInWithPassword /
# resetPasswordForEmail. Distinct from the service-role key.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE_DATABASE_URL=

# Encryption
# 32-byte master key, base64-encoded. Generate with: openssl rand -base64 32
MASTER_KEY_BASE64=

# Cookie signing (Story 1.4)
# 32+ byte HMAC secret for @fastify/cookie signed-cookie protection.
# Generate with: openssl rand -base64 32
COOKIE_SECRET=

# App
PORT=3000
# Public origin used as emailRedirectTo for Supabase Auth confirmation/recovery
# links and for constructing absolute URLs in server responses.
APP_BASE_URL=http://localhost:3000

# Stripe (needed at import time by stripe SDK — set to sk_test_ for local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=

# Mirakl / Worten integration (Story 4.3)
# Worten Mirakl marketplace base URL (used by the key validation route).
# Defaults to https://marketplace.worten.pt in production.
# Set to mock server URL in tests.
WORTEN_INSTANCE_URL=https://marketplace.worten.pt
# A 13-digit EAN from the seller's own catalog, used by the inline key validation (P11 call).
# Required in .env.local and .env.test for Story 4.3 integration tests.
WORTEN_TEST_EAN=
# Timeout in ms for the inline Mirakl key validation call (AbortController cutoff).
# Defaults to 5000ms (NFR-P6). Override to a shorter value in tests.
# MIRAKL_VALIDATION_TIMEOUT_MS=5000

# Logging
# pino log level: trace|debug|info|warn|error|fatal. Default 'info' if unset.
# LOG_LEVEL=info
